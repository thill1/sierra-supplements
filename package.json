{
  "name": "sierra-supplements",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/db/seed-products.ts",
    "db:seed-admins": "tsx src/db/seed-admins.ts",
    "db:seed-admins:vercel": "bash scripts/seed-admins-with-vercel-admin-emails.sh",
    "google:oauth-console": "bash scripts/open-google-oauth-console.sh",
    "setup:check": "node scripts/check-env.js",
    "setup:vercel": "echo 'See docs/DEPLOYMENT.md for Vercel env setup'",
    "dns:cloudflare-vercel": "node scripts/sync-cloudflare-vercel-dns.mjs",
    "dns:cloudflare-vercel:direct": "DNS_PROXIED=false node scripts/sync-cloudflare-vercel-dns.mjs",
    "icons:generate": "node scripts/generate-app-icons.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.1",
    "@libsql/client": "^0.17.0",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@neondatabase/serverless": "^1.0.2",
    "@sentry/nextjs": "^10.45.0",
    "@supabase/supabase-js": "^2.99.3",
    "@vercel/blob": "^2.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "framer-motion": "^12.34.0",
    "gray-matter": "^4.0.3",
    "heic-convert": "^2.1.0",
    "lucide-react": "^0.563.0",
    "next": "16.1.6",
    "next-auth": "5.0.0-beta.30",
    "next-mdx-remote": "^6.0.0",
    "papaparse": "^5.5.3",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.2",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5",
    "vitest": "^2.1.9"
  }
}
