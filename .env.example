# ─── Database (required for store/admin) ────────────────────────
# Supabase: Use Transaction pooler URI (port 6543) for Vercel serverless
# Dashboard → Project Settings → Database → Connection string → URI → Transaction
# Example: postgresql://postgres.[ref]:[PASSWORD]@aws-0-us-west-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://..."

# ─── Auth ──────────────────────────────────────────────────────
# Generate with: npx auth secret
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google Auth (Optional)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email (Resend) ────────────────────────────────────────────
# RESEND_API_KEY="re_..."
ADMIN_EMAIL="admin@sierrasupplements.com"

# ─── Site Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
