# ─── Database (required for store/admin in production) ─────────
# Supabase: Transaction pooler (port 6543). See docs/DATABASE.md
DATABASE_URL="postgresql://..."

# ─── Auth ───────────────────────────────────────────────────────
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Comma-separated emails used for admin access (required on Vercel).
# Must include the exact Google account email you sign in with. Rows in admin_users
# still win for role/active; allowlist grants owner when there is no active row yet.
ADMIN_EMAILS="sierrastrengthsupplements@gmail.com,tghill@gmail.com"

# After editing ADMIN_EMAILS, upsert admin_users:
#   pnpm db:seed-admins
# Playwright merges this list with PLAYWRIGHT_ADMIN_EMAIL in webServer env and runs seed in globalSetup.
# If DATABASE_URL is unset, `pnpm test:e2e` starts Docker Postgres (docker-compose.e2e.yml) and sets DATABASE_URL automatically.

# ─── Local Playwright admin E2E (never set on Vercel) ───────────
# Optional overrides (defaults match tests/e2e-constants.ts):
# PLAYWRIGHT_ADMIN_EMAIL="e2e-admin@sierra-supplements.local"
# E2E_ADMIN_CREDENTIALS_SECRET="local-only-e2e-admin-credentials-secret-min-32___"
# For `next start` E2E only: ALLOW_E2E_CREDENTIALS_ADMIN="true"

# Google Auth (recommended for admin on Vercel — see docs/DEPLOYMENT.md § Google OAuth)
# GOOGLE_CLIENT_ID="....apps.googleusercontent.com"
# GOOGLE_CLIENT_SECRET="GOCSPX-..."

# ─── Email (Resend) ─────────────────────────────────────────────
# RESEND_API_KEY="re_..."
# Fallback when Admin → Settings has no row yet (optional if settings saved in DB)
ADMIN_EMAIL="sierrastrengthsupplements@gmail.com"

# Cal.com → Settings → Developer → Webhooks: URL /api/webhooks/calcom, secret below
# CALCOM_WEBHOOK_SECRET="..."

# ─── Site ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Payments ───────────────────────────────────────────────────
# Active provider: defaults to "stripe". Set to "signapay" only after
# the SignaPay merchant checkout/token flow is implemented for your account.
# PAYMENT_PROVIDER="stripe"

# ─── Catalog (production) ───────────────────────────────────────
# Never set in production unless you intentionally want static fallback:
# ALLOW_HARDCODED_CATALOG="true"
# Local: set DISABLE_HARDCODED_CATALOG=true to force DB-only behavior

# ─── Admin media (Vercel Blob) ───────────────────────────────────
# Create a Blob store in Vercel → Storage; use the read-write token (server only).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── Stripe (optional – card checkout + webhooks) ──────────────
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# Local / staging only: skip Stripe API + signature verification (disabled in production startup checks)
# STRIPE_MOCK_MODE="true"

# ─── SignaPay / Sign2Pay (placeholder until official checkout docs are wired) ──
# Required when PAYMENT_PROVIDER="signapay"
# SIGNAPAY_CLIENT_ID="..."
# SIGNAPAY_API_KEY="..."
# SIGNAPAY_REDIRECT_URI="https://your-site.example/store/thank-you"

# ─── Shared rate limiting (required for production hardening) ───
# Upstash Redis REST credentials used for shared rate limiting on public/admin APIs
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# ─── Supabase Storage (legacy – optional if still using old uploads) ───
# NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # server only
# SUPABASE_STORAGE_BUCKET="store-images"

# ─── Database TLS (optional) ────────────────────────────────────
# If your provider uses a non-public CA, you may need:
# DATABASE_SSL_REJECT_UNAUTHORIZED="false"

# ─── Sentry (optional error tracking) ───────────────────────────
# Server / edge (secret on Vercel — not NEXT_PUBLIC)
# SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
# Browser (same DSN value is typical; required for client + tunnel)
# NEXT_PUBLIC_SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
# Optional: source maps on CI — https://docs.sentry.io/platforms/javascript/guides/nextjs/
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ─── Vercel / strict checks ─────────────────────────────────────
# Local production-like validation: FORCE_PRODUCTION_ENV_CHECK=true
# Emergency only on Vercel: SKIP_PRODUCTION_ENV_CHECK=true
# Optional: enable verbose auth debug logs in production temporarily
# AUTH_DEBUG_LOGS="true"

# ─── Cloudflare DNS (optional — pnpm dns:cloudflare-vercel) ─────
# CLOUDFLARE_API_TOKEN=...   # Zone → DNS Edit + Zone Read; token must cover every zone below
# CLOUDFLARE_ZONE_ID=...     # Optional shortcut when syncing only sierrastrengthsupplements.com
# CLOUDFLARE_EXTRA_ZONES=sierrastrongsupplements.com   # Typo domain (comma-separated if several)
# DNS_PROXIED=false          # Set to use DNS-only (gray cloud); default is proxied (orange)
# CLOUDFLARE_SET_SSL_STRICT=false  # Skip API SSL=strict (needs Zone Settings → Edit on the token)
