# ─── Database (required for store/admin) ────────────────────────
# Supports: Supabase, Neon, Vercel Postgres, or any Postgres
# See docs/DATABASE.md for provider-specific setup
#
# Supabase: Use Transaction pooler (port 6543)
# Neon: Copy connection string from dashboard
# Vercel: POSTGRES_URL is auto-injected when you add Postgres
DATABASE_URL="postgresql://..."

# ─── Auth ──────────────────────────────────────────────────────
# Generate with: npx auth secret
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google Auth (Optional)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Email (Resend) ────────────────────────────────────────────
# RESEND_API_KEY="re_..."
ADMIN_EMAIL="admin@sierrasupplements.com"

# ─── Site Config ───────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Supabase Storage (optional – admin product image uploads) ─
# Same project as DATABASE_URL is fine. See docs/SUPABASE-STORAGE.md
# NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # server only – never expose
# SUPABASE_STORAGE_BUCKET="store-images"
